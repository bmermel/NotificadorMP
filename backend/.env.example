# =============================================================================
# mp-alertas-recepcion — variables de entorno (backend)
# Copiá este archivo como ".env" en la carpeta backend y completá los valores.
# Nunca subas ".env" al repositorio (contiene secretos).
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor HTTP
# -----------------------------------------------------------------------------
# Puerto donde escucha Express (API, webhook, archivos del frontend en desarrollo).
PORT=3001

# -----------------------------------------------------------------------------
# Mercado Pago — API
# -----------------------------------------------------------------------------
# Token de acceso para llamar a la API (GET /v1/payments/:id tras recibir el webhook).
# Obtenelo en: Developers > Tu aplicación > Credenciales (producción o prueba).
# Debe coincidir con el ambiente en el que probás (test vs producción).
MP_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Mercado Pago — Webhooks (firma de notificaciones)
# -----------------------------------------------------------------------------
# Secreto que genera Mercado Pago al configurar la URL de webhook en "Tu integración".
# Sirve para validar que el POST lo envió MP (cabeceras x-signature y x-request-id).
# Si no configurás webhooks con firma, podés dejarlo vacío y desactivar la validación abajo.
MP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Mercado Pago — Validación de firma
# -----------------------------------------------------------------------------
# true  = exige cabeceras x-signature / x-request-id válidas y MP_WEBHOOK_SECRET.
#         Recomendado en producción con URL pública de webhook.
# false = no valida la firma (útil en desarrollo local al simular POST sin cabeceras MP).
MP_USE_SIGNATURE_VALIDATION=true

# -----------------------------------------------------------------------------
# Webhook de pagos (legacy / opcional)
# -----------------------------------------------------------------------------
# true  = procesa POST /webhooks/mercadopago orientado a topic payment
# false = ignora ese webhook (200 ignored), útil si usás solo monitor de transferencias
MP_WEBHOOK_PAYMENT_ENABLED=true

# -----------------------------------------------------------------------------
# Monitor de transferencias (polling de movimientos)
# -----------------------------------------------------------------------------
# Habilita un polling periódico para detectar transferencias entrantes aprobadas.
MP_TRANSFER_MONITOR_ENABLED=true

# Intervalo de polling en milisegundos (recomendado 15000 o 30000).
MP_TRANSFER_MONITOR_INTERVAL_MS=30000

# Ventana de búsqueda hacia atrás para consultar movimientos recientes.
# Mayor valor = más tolerante a retrasos, pero más datos por consulta.
MP_TRANSFER_MONITOR_LOOKBACK_MS=86400000

# Máximo de resultados por consulta al endpoint de búsqueda de pagos.
MP_TRANSFER_MONITOR_LIMIT=50

# Tipos permitidos para considerar "transferencia recibida" (payment_type_id).
# Ajustable según tu cuenta/país. Por defecto: bank_transfer y account_money.
MP_TRANSFER_ALLOWED_PAYMENT_TYPES=bank_transfer,account_money

# Cantidad máxima de IDs ya procesados guardados para deduplicación.
MP_TRANSFER_MONITOR_MAX_PROCESSED_IDS=500

# Archivo local donde se persisten IDs procesados entre reinicios.
MP_TRANSFER_MONITOR_STATE_FILE=./data/transfer-monitor-state.json

# Logs detallados por movimiento (resumen de campos, motivo de descarte o aceptación).
# En producción dejar en false para menos ruido en logs.
MP_TRANSFER_MONITOR_DEBUG=false

# Si DEBUG=true, permite además volcar JSON del ítem truncado (emails enmascarados en el string).
MP_TRANSFER_MONITOR_LOG_RAW=false
