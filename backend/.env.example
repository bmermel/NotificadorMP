# =============================================================================
# mp-alertas-recepcion — variables de entorno (backend)
# Copiá este archivo como ".env" en la carpeta backend y completá los valores.
# Nunca subas ".env" al repositorio (contiene secretos).
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor HTTP
# -----------------------------------------------------------------------------
# Puerto donde escucha Express (API, webhook, archivos del frontend en desarrollo).
PORT=3001

# -----------------------------------------------------------------------------
# Mercado Pago — API
# -----------------------------------------------------------------------------
# Token de acceso para llamar a la API (GET /v1/payments/:id tras recibir el webhook).
# Obtenelo en: Developers > Tu aplicación > Credenciales (producción o prueba).
# Debe coincidir con el ambiente en el que probás (test vs producción).
MP_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Mercado Pago — Webhooks (firma de notificaciones)
# -----------------------------------------------------------------------------
# Secreto que genera Mercado Pago al configurar la URL de webhook en "Tu integración".
# Sirve para validar que el POST lo envió MP (cabeceras x-signature y x-request-id).
# Si no configurás webhooks con firma, podés dejarlo vacío y desactivar la validación abajo.
MP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Mercado Pago — Validación de firma
# -----------------------------------------------------------------------------
# true  = exige cabeceras x-signature / x-request-id válidas y MP_WEBHOOK_SECRET.
#         Recomendado en producción con URL pública de webhook.
# false = no valida la firma (útil en desarrollo local al simular POST sin cabeceras MP).
MP_USE_SIGNATURE_VALIDATION=true
